    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
